# Operating system cruft
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment & secrets
.env
.env.*
!.env.example

# Logs & temp
*.log
tmp/
.cache/

# Go (toolchain chosen in #1)
# Compiled binaries — including the unified agentgpu binary
/agentgpu
*.exe
*.test
*.out
# Coverage profiles + rendered reports (make cover / make cover-html / CI)
coverage.txt
coverage.out
coverage.gate.out
coverage.func.txt
coverage.html
# We use Go modules, not vendoring
/vendor/

# GoReleaser build output
/dist/

# OpenAPI rendered docs (generated by `redocly build-docs` / the CI openapi job
# and the GitHub Pages publish workflow)
/openapi.html
/_site/

# Admin console (#100) dev/test toolchain (Node is dev/test/CI-only; never a
# runtime dep). The generated *_templ.go and the built app.css ARE committed (so
# `go build` needs no Node) and are deliberately NOT ignored.
node_modules/
npm-debug.log*
ui/test-results/
ui/playwright-report/
ui/blob-report/
ui/.playwright/
.tailwindcss-cache
