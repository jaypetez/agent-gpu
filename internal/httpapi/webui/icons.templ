package webui

// icons.templ — inline SVG glyphs. Inlining (not <img> or an icon font) keeps the
// console self-contained: no external request, no webfont, CSP-clean. Each icon is
// 16x16 on a 24 viewBox, stroke-based, inheriting currentColor so it tints with
// its surrounding text token. All are aria-hidden — the adjacent text label is the
// accessible name (status is conveyed by text, not the glyph alone).

// navIcon dispatches to the named sidebar glyph. An unknown name falls back to a
// neutral dot so a new section never renders a broken icon.
templ navIcon(name string) {
	switch name {
		case "overview":
			@iconGauge()
		case "workers":
			@iconServer()
		case "keys":
			@iconKey()
		case "usage":
			@iconChart()
		case "telemetry":
			@iconActivity()
		case "logs":
			@iconLogs()
		case "audit":
			@iconShield()
		case "config":
			@iconSliders()
		default:
			@iconDot()
	}
}

templ iconGauge() {
	<svg class="size-4 flex-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
		<path d="M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"></path>
		<path d="m13.5 10.5 3-3"></path>
		<path d="M4 18a8 8 0 1 1 16 0"></path>
	</svg>
}

templ iconServer() {
	<svg class="size-4 flex-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
		<rect x="3" y="4" width="18" height="7" rx="1.5"></rect>
		<rect x="3" y="13" width="18" height="7" rx="1.5"></rect>
		<path d="M7 7.5h.01M7 16.5h.01"></path>
	</svg>
}

templ iconKey() {
	<svg class="size-4 flex-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
		<circle cx="7.5" cy="15.5" r="3.5"></circle>
		<path d="m10 13 9-9"></path>
		<path d="m16 7 2 2"></path>
		<path d="m13 10 2 2"></path>
	</svg>
}

templ iconChart() {
	<svg class="size-4 flex-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
		<path d="M4 19V5"></path>
		<path d="M4 19h16"></path>
