package webui

// login.templ — the console sign-in. A single focused card on the instrument-panel
// ground: the operator pastes an admin API token, the server validates it via the
// existing auth.Authenticate and sets an HttpOnly session cookie (the token never
// touches JavaScript). Copy is in the operator's voice; the error region is an
// in-voice explanation of what to fix, not an apology.

templ Login(d LoginData) {
	<html lang="en" class="dark">
	<head>
		<meta charset="utf-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1"/>
		<meta name="color-scheme" content="dark"/>
		<title>{ pageTitle("Sign in") }</title>
		<link rel="icon" href={ d.AssetPath + "/img/favicon.svg" } type="image/svg+xml"/>
		<link rel="stylesheet" href={ d.AssetPath + "/css/app.css" }/>
	</head>
	<body class="grid min-h-screen place-items-center bg-ground px-4 text-fg">
		<main class="w-full max-w-sm">
			<div class="mb-6 flex items-center gap-2">
				<span class="live-dot" aria-hidden="true"></span>
				<span class="font-mono text-base font-semibold tracking-wide text-fg">agent-gpu</span>
				<span class="text-fg-faint" aria-hidden="true">/</span>
				<span class="text-base text-fg-muted">console</span>
			</div>
			<div class="panel">
				<div class="panel-body">
					<h1 class="text-xl font-semibold text-fg">Sign in to the console</h1>
					<p class="mt-1 text-sm text-fg-muted">
						Paste an admin API token to manage the fleet. Read access to a section
						appears only if your token holds its scope.
					</p>
					if d.Error != "" {
						<div role="alert" class="mt-4 flex items-start gap-2 rounded-md border border-danger bg-danger-soft px-3 py-2 text-sm text-danger">
							@iconAlert()
							<span>{ d.Error }</span>
						</div>
					}
					<form method="post" action={ templ.SafeURL(d.AssetPath + "/../login") } class="mt-5 flex flex-col gap-4">
						@csrfField(d.CSRFToken)
						<input type="hidden" name="next" value={ d.Next }/>
						<div class="flex flex-col gap-1.5">
							<label for="token" class="text-sm font-medium text-fg">Admin API token</label>
							<input
								id="token"
								name="token"
								type="password"
								required
								autocomplete="off"
								autocapitalize="off"
								spellcheck="false"
								autofocus
								placeholder="agpu_…"
								class="field font-mono"
								aria-describedby="token-hint"
							/>
							<p id="token-hint" class="text-xs text-fg-faint">
								Mint one with
								<code class="rounded-sm bg-surface-2 px-1 py-0.5 text-fg-muted">agentgpu key create --role admin</code>.
							</p>
						</div>
						<button type="submit" class="btn btn-primary w-full">Sign in</button>
					</form>
				</div>
			</div>
			<p class="mt-4 text-center text-xs text-fg-faint">
				Tokens are validated server-side and stored only as a session cookie.
			</p>
		</main>
	</body>
	</html>
}

// ErrorPage is a standalone, unauthenticated error page (404/500/…) for the
// console. A browser hitting a bad console URL expects HTML, not the API's JSON
// envelope, so this renders a calm in-voice page on the same instrument-panel
// ground with a way back to the console.
templ ErrorPage(assetPath, status, message, homeHref string) {
	<html lang="en" class="dark">
	<head>
		<meta charset="utf-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1"/>
		<meta name="color-scheme" content="dark"/>
		<title>{ pageTitle(status) }</title>
		<link rel="icon" href={ assetPath + "/img/favicon.svg" } type="image/svg+xml"/>
		<link rel="stylesheet" href={ assetPath + "/css/app.css" }/>
	</head>
	<body class="grid min-h-screen place-items-center bg-ground px-4 text-fg">
		<main class="w-full max-w-sm text-center">
			<p class="font-mono text-sm uppercase tracking-widest text-fg-faint">{ status }</p>
			<p class="mt-3 text-lg text-fg">{ message }</p>
			<a href={ templ.SafeURL(homeHref) } class="btn btn-primary mt-6 inline-flex">Back to the console</a>
		</main>
	</body>
	</html>
}
