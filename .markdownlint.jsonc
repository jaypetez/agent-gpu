{
  // https://github.com/DavidAnson/markdownlint/blob/main/doc/Rules.md
  "default": true,
  "MD013": false, // line length — prose and tables wrap naturally
  "MD033": false, // inline HTML — allowed (badges, details)
  "MD041": false, // first line need not be a top-level heading (templates)
  "MD024": { "siblings_only": true }, // duplicate headings ok if not siblings
  "MD046": false, // code block style — allow both fenced and indented
  "MD010": { "code_blocks": false } // hard tabs ok inside code blocks (Go is tab-indented)
}
