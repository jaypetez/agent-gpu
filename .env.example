# agent-gpu Compose configuration — copy to `.env` and edit as needed.
#
#   cp .env.example .env
#
# Every value here has a built-in default in compose.yaml (via ${VAR:-default}),
# so the stack runs even with no .env present. `.env` itself is gitignored; only
# this example is committed.

# Model the one-shot `ollama-init` service pulls and the worker then advertises.
# qwen2:0.5b is tiny (~350 MB) so the end-to-end demo is fast. Use any Ollama tag
# (e.g. llama3.2:1b, qwen2.5:0.5b). It must be pulled before inference, otherwise
# a request for it queues until a worker serves it.
AGENTGPU_MODEL=qwen2:0.5b

# Host port the public OpenAI-compatible HTTP API is published on (container 8080).
AGENTGPU_HTTP_PORT=8080

# Worker heartbeat cadence. A short interval makes a freshly pulled model become
# routable quickly in dev; production typically leaves the 15s default.
AGENTGPU_HEARTBEAT_INTERVAL=5s

# Per-key quota defaults applied to keys without an explicit override
# (0 = unlimited). Raise to enforce a fleet-wide default.
AGENTGPU_DEFAULT_RPM=0
AGENTGPU_DEFAULT_TPM=0

# Credentials for the provisioned Postgres service. NOTE: Postgres (and Redis) are
# provisioned for the forthcoming durable-state backend but are NOT wired to any
# code path yet — the server persists to the agentgpu-data volume (file store)
# today. Change these before exposing the stack beyond your machine.
POSTGRES_USER=agentgpu
POSTGRES_PASSWORD=agentgpu
POSTGRES_DB=agentgpu
