# Normalize line endings: store text as LF in the repo, check out native on Windows.
* text=auto eol=lf

# Always-LF for shell scripts so they stay executable on Unix runners.
*.sh text eol=lf

# Generated protobuf Go stubs: committed for reproducible builds, but marked
# generated so they collapse in diffs and don't skew language stats.
*.pb.go linguist-generated=true -diff
