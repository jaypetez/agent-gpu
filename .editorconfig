# EditorConfig — consistent formatting across editors. https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# Keep trailing whitespace off, but Markdown uses two trailing spaces for hard
# line breaks — leave that to the author rather than stripping it.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
